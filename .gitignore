# Ecosistema Multi-LLM Jarvis - Git Ignore Maestro

# --- Credenciales y Seguridad ---
*.json
*.env
!env.example
!mcp-alias-map.json
!plugin-map.json
!*.conf.yml
!*.toml
!runtime/openclaw-jarvis/registry.json
!runtime/openclaw-jarvis/config/*.json
!runtime/openclaw-jarvis/config-set.specialist-policy.json
!runtime/openclaw-jarvis/config-set.secrets-file.json
!**/*.example.json

# Exclusiones de seguridad específicas (No versionar llaves/auth)
.credentials.json
auth.json
oauth_creds.json
google_accounts.json

# --- Bases de Datos y Estado ---
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db
session_index.jsonl
history.jsonl

# --- Logs y Caché ---
*.log
cache/
logs/
tmp/
.tmp/
node_modules/
.venv/
__pycache__/

# --- Directorios de sistema ignorados por seguridad ---
.security/
.sandbox/
.claude-backup-pre-migration/
runtime/openclaw-jarvis/runs/
runtime/openclaw-jarvis/agents/*/.openclaw/
runtime/openclaw-jarvis/var/

# --- Otros archivos de entorno ---
.DS_Store
Thumbs.db
