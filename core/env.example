# J.A.R.V.I.S. — Environment Variables Example
# Copy to jarvis.env and fill in your API keys
# cp env.example jarvis.env

# === LLM Configuration ===
OLLAMA_URL=http://localhost:11434
PRIMARY_MODEL=qwen2.5:3b
# Other local models: mistral:7b, llama3.2:3b, phi3.5:3.8b

# Groq (free tier: 30K tokens/min) — https://console.groq.com
GROQ_API_KEY=

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# === Speech ===
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large-v3
WHISPER_DEVICE=cuda
# Options: cuda, cpu

TTS_ENGINE=pyttsx3
# Options: pyttsx3 (offline), gtts (online)

# === Telegram Bot (optional) ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (get from @userinfobot). Comma-separated for multiple users.
TELEGRAM_ALLOWED_USERS=

# === RAG / Personal Knowledge Base (optional) ===
# Path to your Obsidian vault or notes directory
OBSIDIAN_VAULT_PATH=
# Example: OBSIDIAN_VAULT_PATH=/home/emmanuel/Documents/OBSIDIAN
# Example (WSL2): OBSIDIAN_VAULT_PATH=/mnt/c/Users/Acer Nitro/Documents/OBSIDIAN

# Enable/disable RAG for each query (default: true)
RAG_ENABLED=true

# === Wake Word (optional) ===
# Requires: pip install openwakeword pyaudio
# WAKE_WORD_THRESHOLD=0.5

# === Weather (optional) ===
# OpenWeatherMap free tier: https://openweathermap.org/api
OWM_API_KEY=

# === Web Search (optional) ===
# Brave Search API: https://api.search.brave.com
BRAVE_API_KEY=

# === Server ===
HOST=0.0.0.0
PORT=8000

# === Database ===
DB_PATH=data/jarvis.db
